# Dependencies
node_modules/

# Build output
dist/
build/

# Secrets — never commit
.env
**/.env
!**/.env.example

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db

# Portable tooling
/.tools/

# Prisma local
**/prisma/*.db

# transient cloudflared logs
.cloudflared.*
backend/.railway-db-url
backend/.coverage-cache/
.npm-cache/

# Локальные ИИ-инструменты (Stable Diffusion и модели) — 7 ГБ, не для репозитория
tools/

# Кеш моделей CLIP (~293 МБ) — скачивается автоматически при первом запуске
backend/.models-cache/
# Выгрузки каталога (гигабайты, восстановимы из БД)
exports/

# Собирается Railway из frontend/dist при каждом деплое — не хранить в git
# (закоммиченная версия перезатирала свежую сборку через COPY . /app)
backend/public/
