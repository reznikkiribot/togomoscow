# Copy this file to .env and fill in real values. .env is gitignored.

# Local Postgres from docker-compose
DATABASE_URL="postgresql://yelp:yelp_dev_password@localhost:5432/yelp?schema=public"

# Telegram bot token from BotFather (bot: togomoscow_bot)
# KEEP THIS SECRET — never commit it.
TELEGRAM_BOT_TOKEN="PUT_YOUR_BOT_TOKEN_HERE"

# API port
PORT=3000

# Comma-separated Telegram IDs granted ADMIN rights (approve ownership claims)
ADMIN_TELEGRAM_IDS=""

# Pexels API key (free) — used to fetch free, commercial-use photos
PEXELS_API_KEY=""

# VK service token (free) for reading OPEN community walls via the official VK API.
# Create a VK app at https://vk.com/apps?act=manage → get a "service" access token.
# Leave empty to skip VK ingestion. Telegram works without any token (public t.me/s/).
VK_TOKEN=""

# Local open-source LLM (Ollama) for cleaning up parsed posts — extracts dish
# names and prunes false positives. Free, runs on this machine. Install:
#   winget install Ollama.Ollama   then   ollama pull qwen2.5:3b
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:3b"

# Shared secret for the Google Sheet bridge (Apps Script webhook). Make it long
# and random. Used by GET /api/sheet/export and POST /api/sheet/sync.
SHEET_SECRET=""

# S3-compatible storage (MinIO locally, Yandex Object Storage in prod)
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="uploads"
